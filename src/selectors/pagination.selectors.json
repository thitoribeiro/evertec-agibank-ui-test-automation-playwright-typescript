{
  "container": ".page-numbers, .pagination, nav.navigation",
  "nextButton": "a:has-text('Próxima »'), a.next",
  "prevButton": "a:has-text('« Anterior'), a.prev",
  "currentPage": "span.current, .page-numbers.current",
